# =============================================================================
# Clin360 — Landing Page · Variaveis de Ambiente
# Copie para .env.local (dev) e configure as mesmas no Vercel (producao).
# =============================================================================

# --- Analytics / Tracking (trafego pago) -------------------------------------
# Google Analytics 4 — Measurement ID (ex: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
# Meta Pixel — Pixel ID (ex: 123456789012345). SEM ele o Pixel nao carrega e o
# Meta Ads nao consegue otimizar por conversao.
NEXT_PUBLIC_META_PIXEL_ID=

# --- Contato (CTA e captura de lead) -----------------------------------------
# WhatsApp comercial — SO DIGITOS com DDI+DDD (ex: 5551999887766). Usado nos
# botoes "Falar pelo WhatsApp" e no envio do formulario.
NEXT_PUBLIC_WHATSAPP_COMMERCIAL=
# Versao formatada do numero, so para exibir (ex: (51) 99988-7766)
NEXT_PUBLIC_WHATSAPP_DISPLAY=
# Email de contato exibido na pagina (ex: contato@clin360.com.br)
NEXT_PUBLIC_CONTACT_EMAIL=

# --- Captura de lead -> Supabase (server-side, NAO usar NEXT_PUBLIC) ----------
# URL do projeto Supabase onde fica a tabela `leads` (migration 00086 do SaaS).
SUPABASE_URL=
# Service role key (server-only). Usada so na rota /api/lead para gravar o lead.
# NUNCA exponha no client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Chat widget (IA de vendas) ----------------------------------------------
# Chave Anthropic usada SO no servidor pela rota /api/chat. Sem ela o chat
# degrada para uma mensagem de "assistente sendo ativado".
ANTHROPIC_API_KEY=
